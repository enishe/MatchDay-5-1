# Copy to backend/.env and fill in real values (never commit .env)

# Neon PostgreSQL — paste from Neon Dashboard → Connection string
# Must include ?sslmode=require (Neon adds this by default)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Set DB_SSL=false only for local Postgres without TLS
# DB_SSL=false

JWT_SECRET=change-me-in-production-use-long-random-string

# Public URL of your frontend (for CORS and invite links)
FRONTEND_URL=http://localhost:5173

# Optional: Authorization: Bearer <CRON_SECRET> for POST /api/auto-cancel
CRON_SECRET=
